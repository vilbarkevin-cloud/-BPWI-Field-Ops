rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { 
        return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function getRole(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)/profile/info)
             ? get(/databases/$(database)/documents/users/$(uid)/profile/info).data.role
             : '';
    }
    function isAdmin(uid) {
      return getRole(uid) == 'admin' || 
             getRole(uid) == 'operations_manager' || 
             (getRole(uid) is string && getRole(uid).matches('.*[hH]ead.*'));
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin(request.auth.uid);
    }

    // Validation Blueprint for Task
    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'priority', 'location', 'status', 'createdAt', 'updatedAt']) 
             && data.keys().size() >= 7
             && data.title is string && data.title.size() <= 200
             && data.priority is string && data.priority.matches('^(low|medium|high)$')
             && data.location is string && data.location.size() <= 200
             && data.status is string && data.status.matches('^(pending|in-progress|completed)$')
             && data.createdAt is timestamp
             && data.updatedAt is timestamp;
    }

    // Validation Blueprint for Activity
    function isValidActivity(data) {
      return data.keys().hasAll(['userId', 'type', 'area', 'status', 'date', 'createdAt', 'updatedAt'])
             && data.keys().size() >= 7
             && data.type is string && data.type.size() <= 100
             && data.area is string && data.area.size() <= 100
             && data.status is string && data.status.size() <= 100
             && data.createdAt is timestamp
             && data.updatedAt is timestamp;
    }

    // Validation Blueprint for Inventory
    function isValidInventory(data) {
      return data.keys().hasAll(['name', 'category', 'currentStock', 'unit', 'minThreshold', 'lastUpdated', 'createdAt', 'updatedAt', 'userId'])
             && data.name is string
             && data.category is string
             && data.currentStock is number
             && data.unit is string
             && data.minThreshold is number
             && data.lastUpdated is string
             && data.createdAt is timestamp
             && data.updatedAt is timestamp;
    }

    // Validation Blueprint for Incident
    function isValidIncident(data) {
      return data.keys().hasAll(['type', 'severity', 'facility', 'summary', 'reportedBy', 'status', 'createdAt'])
             && data.type is string
             && data.severity is string
             && data.facility is string
             && data.summary is string
             && data.reportedBy is string
             && data.status is string
             && data.createdAt is timestamp;
    }

    match /users/{userId}/workLogs/{logId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }
    
    match /users/{userId}/tasks/{taskId} {
      allow read: if isSignedIn() && isOwnerOrAdmin(userId);
      
      allow create: if isSignedIn() 
                    && isOwnerOrAdmin(userId)
                    && isValidId(taskId)
                    && isValidId(userId)
                    && isValidTask(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn()
                    && isOwnerOrAdmin(userId)
                    && isValidId(taskId)
                    && isValidId(userId)
                    && isValidTask(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'priority', 'location', 'description', 'assignedTo', 'deadline', 'isSynced', 'status', 'updatedAt', 'photoUrl', 'consumedParts', 'linkedActivity', 'joNumber', 'accountNumber', 'accountName', 'completedAt', 'tatJustification', 'notes', 'linkedAssetId', 'updatedBy'])
                    );
      allow delete: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/profile/{docId} { 
       allow read: if isSignedIn() && isOwnerOrAdmin(userId);
       allow write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/inventory/{itemId} {
      allow read: if isSignedIn() && isOwnerOrAdmin(userId);
      
      allow create: if isSignedIn() 
                    && isOwnerOrAdmin(userId)
                    && isValidId(itemId)
                    && isValidId(userId)
                    && isValidInventory(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn()
                    && isOwnerOrAdmin(userId)
                    && isValidId(itemId)
                    && isValidId(userId)
                    && isValidInventory(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /{path=**}/tripTickets/{ticketId} {
      allow read: if isSignedIn() && isAdmin(request.auth.uid);
    }
    
    match /{path=**}/attendance/{attendanceId} {
      allow read: if isSignedIn() && isAdmin(request.auth.uid);
    }

    match /{path=**}/incidents/{incidentId} {
      allow read: if isSignedIn() && isAdmin(request.auth.uid);
    }

    match /shared/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /shared/vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /users/{userId}/tripTickets/{ticketId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/activities/{activityId} {
      allow read: if isSignedIn() && isOwnerOrAdmin(userId);
      
      allow create: if isSignedIn() 
                    && isOwnerOrAdmin(userId)
                    && isValidId(activityId)
                    && isValidId(userId)
                    && isValidActivity(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn()
                    && isOwnerOrAdmin(userId)
                    && isValidId(activityId)
                    && isValidId(userId)
                    && isValidActivity(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['type', 'area', 'siteOrWell', 'blockLot', 'staff', 'date', 'status', 'isSynced', 'details', 'updatedAt', 'title', 'data'])
                    );
      allow delete: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/attendance/{attendanceId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/areas/{areaId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/staff/{staffId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/customers/{customerId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/activityTypes/{typeId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/incidents/{incidentId} {
      allow read: if isSignedIn() && isOwnerOrAdmin(userId);
      allow create: if isSignedIn() && isOwnerOrAdmin(userId)
                    && isValidId(incidentId)
                    && isValidIncident(incoming());
      allow update: if isSignedIn() && isOwnerOrAdmin(userId) && isValidIncident(incoming());
      allow delete: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/CalendarEvents/{eventId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/ManpowerPalette/{paletteId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/huddle_reports/{reportId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }

    match /users/{userId}/handovers/{handoverId} {
      allow read, write: if isSignedIn() && isOwnerOrAdmin(userId);
    }
  }
}
